{
  "name": "lucky-run",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vp test",
    "lint:all": "vp check --no-fmt 'src/**/*.{js,jsx,ts,tsx}'",
    "lint": "vp check --no-fmt",
    "format": "vp check --no-lint --fix",
    "gen:api:server": "node_modules/@core/bin/gen-api-server.sh",
    "gen:api:cli": "node_modules/@core/bin/gen-api-client.sh",
    "gen:api:docs": "npx -y @redocly/cli build-docs ./src/infra/api/schema/schema.json -o ./src/infra/api/schema/docs.html || true",
    "gen:api": "pnpm gen:api:server && pnpm gen:api:cli",
    "run:storybook": "storybook dev",
    "test:storybook": "test-storybook",
    "build": "pnpm build:api && pnpm build:web",
    "gen:app-router": "node_modules/@router/bin/gen-app-router.js",
    "build:web": "pnpm gen:app-router -y && vp build",
    "dev": "vp dev",
    "dev:web": "vp dev",
    "run:web": "vp preview",
    "build:api": "pnpm gen:api && tsc -p ./tsconfig.api.json && tsc-alias -p ./tsconfig.api.json",
    "ensure-buckets": "node_modules/@backend/bin/ensure-buckets.js",
    "dev:api": "nodemon --config ./api/nodemon.json",
    "run:api": "node dist/api/api/index.js",
    "storybook": "storybook dev",
    "build:storybook": "storybook build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@backend": "npm:@jeliq/app-sdk-backend-supabase@^3.0.7",
    "@core": "npm:@jeliq/app-sdk-core@^3.0.8",
    "@llm": "npm:@jeliq/app-sdk-llm@^1.2.6",
    "@react-router/node": "^7.13.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@router": "npm:@jeliq/app-sdk-react-router@^1.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "express-async-errors": "^3.1.1",
    "express-openapi": "^12.1.3",
    "express-openapi-validator": "^5.6.2",
    "isbot": "^5.1.36",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-router": "^7.13.2",
    "react-toastify": "^11.0.5",
    "tailwindcss": "^4.2.2",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@react-router/dev": "^7.13.2",
    "@react-router/fs-routes": "^7.13.2",
    "@storybook/addon-essentials": "8",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/builder-vite": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "8",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "msw": "^2.12.14",
    "msw-storybook-addon": "^2.0.6",
    "nodemon": "^3.1.14",
    "storybook": "^8.6.18",
    "storycap": "^5.0.1",
    "supabase": "^2.84.4",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
